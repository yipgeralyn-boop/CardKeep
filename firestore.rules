rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can only read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can write their own document BUT cannot self-grant Pro.
      // isPro can only be set to true by the server (Cloud Function / Admin SDK).
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && (
                     !('isPro' in request.resource.data)
                     || request.resource.data.isPro == false
                     || (resource != null && resource.data.isPro == true)
                   );
    }
  }
}
